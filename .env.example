# WhatsApp Bot Config
# Word that triggers the bot when mentioned in a group (case-insensitive, matched as a standalone token; "@pazgu" also works)
BOT_PREFIX=pazgu

# Group JIDs to allow (get from logs after connecting)
ALLOWED_GROUPS=

# Group name mapping — format: jid1:name1,jid2:name2
GROUP_NAMES=

# DM JIDs allowed for testing
TEST_DM_JIDS=

# User phone numbers to allow (empty = everyone)
ALLOWED_USERS=

# Admins — get group_messages tool + slash commands
ADMIN_USERS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX=10
GROUP_COOLDOWN_MS=5000

# Anthropic
ANTHROPIC_API_KEY=

# Agent runtime paths (Railway volume at /data)
SESSIONS_DIR=/data/sessions
AGENTS_MD_PATH=/data/agent/AGENTS.md
MESSAGES_DIR=/data/messages
IMAGES_DIR=/data/images
# Contact store (phone → first name from WhatsApp pushName, used for recap attribution)
CONTACTS_FILE=/data/contacts.json

# Baileys auth persistence
BAILEYS_AUTH_DIR=/data/baileys-auth
# Base64 tar.gz of baileys-auth/ for first-deploy restore (optional)
BAILEYS_AUTH_B64=

# Link enrichment (optional)
FIRECRAWL_API_KEY=

# Podcast audio recaps (ElevenLabs TTS)
# Get API key: elevenlabs.io → Settings → API Keys
# Get voice_id: open any voice → "..." menu → Copy Voice ID
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Anti-abuse for /podcast
PODCAST_MAX_PER_DAY=2
PODCAST_COOLDOWN_MS=1800000
PODCAST_USAGE_FILE=/data/podcast-usage.json

# Messages API auth
API_KEY=

# Railway
PORT=3000
